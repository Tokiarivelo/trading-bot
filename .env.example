# Copy to .env and fill in. NEVER commit .env.
# MT5 account credentials are NOT stored here — they are entered in the app UI,
# encrypted with a key held in the OS keyring, and forwarded to the gateway
# only at connect time.

# Backend
TB_DATABASE_URL=sqlite+aiosqlite:///./data/trading.db
TB_GATEWAY_URL=http://127.0.0.1:8787
TB_GATEWAY_SHARED_SECRET=change-me-long-random-string

# AI providers (leave empty to disable a provider). Per-task selection lives
# in configs/ai.yaml / the Settings page — see AI_PROVIDERS_CONFIGURATION.md
# for full setup instructions. Every key below can also be set (or
# overridden) from the Settings page instead — a settings-page key always
# wins over the value here, and is encrypted at rest, never written back to
# this file.
TB_ANTHROPIC_API_KEY=
TB_OPENAI_API_KEY=
TB_GEMINI_API_KEY=
TB_MISTRAL_API_KEY=
TB_GROQ_API_KEY=
TB_DEEPSEEK_API_KEY=
TB_XAI_API_KEY=
TB_OLLAMA_URL=http://127.0.0.1:11434
# Claude Code CLI (headless `claude -p`) — uses your local `claude login`
# subscription, not TB_ANTHROPIC_API_KEY. Leave binary at "claude" if it's
# on PATH; only set claude_code_extra_args for advanced flags (e.g. --agent).
TB_CLAUDE_CODE_BINARY=claude
TB_CLAUDE_CODE_EXTRA_ARGS=
# OpenClaw — UNVERIFIED integration, see AI_PROVIDERS_CONFIGURATION.md.
TB_OPENCLAW_URL=
TB_OPENCLAW_API_KEY=

# News calendar (only needed if configs/news.yaml calendar_source is
# "finnhub" — forexfactory needs no key).
TB_FINNHUB_API_KEY=

# App auth (§11) — protects every route, since the bot can place live
# trades. Leave empty for bare local dev (no login required).
TB_APP_PASSWORD=

# Alerting (Phase 9) — channel is only used if also enabled in
# configs/alerting.yaml. Leave empty to disable a channel.
TB_TELEGRAM_BOT_TOKEN=
TB_TELEGRAM_CHAT_ID=
TB_SMTP_USERNAME=
TB_SMTP_PASSWORD=
