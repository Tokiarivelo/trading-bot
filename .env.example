# Copy to .env and fill in. NEVER commit .env.
# MT5 account credentials are NOT stored here — they are entered in the app UI,
# encrypted with a key held in the OS keyring, and forwarded to the gateway
# only at connect time.

# Backend
TB_DATABASE_URL=sqlite+aiosqlite:///./data/trading.db
TB_GATEWAY_URL=http://127.0.0.1:8787
TB_GATEWAY_SHARED_SECRET=change-me-long-random-string

# AI providers (leave empty to disable a provider)
TB_ANTHROPIC_API_KEY=
TB_OLLAMA_URL=http://127.0.0.1:11434
